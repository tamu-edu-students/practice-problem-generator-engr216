<head>
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css" rel="stylesheet">
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<div class="w-full flex flex-col bg-[#9aa8c5] min-h-screen">
  <!-- Navbar -->
  <div class="navbar bg-black text-white px-6 w-full fixed top-0 z-50 shadow-lg">
    <div class="flex-1">
      <a href="/teacher_dashboard" class="btn bg-transparent text-white border-transparent hover:border-blue-700 hover:bg-blue-500 hover:text-white transition">
        Dashboard
      </a>
    </div>
    <div class="flex-none">
      <div class="dropdown dropdown-end">
        <button class="btn bg-transparent text-white border-transparent hover:border-blue-700 hover:bg-blue-500 hover:text-white transition">
          Account ▼
        </button>
        <ul class="dropdown-content menu p-2 shadow bg-black text-white rounded-box w-36">
          <li><a href="/teacher_dashboard" class="hover:bg-gray-700">Dashboard</a></li>
          <li><a href="/logout" class="hover:bg-gray-700">Logout</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="flex flex-col items-center justify-center flex-grow w-full p-6 mt-16">
    <h1 class="text-4xl font-bold mb-6 text-black">
      <%= "#{@student.first_name} #{@student.last_name}" %>’s Problem History
    </h1>

    <div class="w-full max-w-4xl bg-black text-white shadow-lg rounded-lg p-6">
      <% if @student %>
        <!-- Summary Section -->
        <div class="mb-6">
          <h2 class="text-2xl font-semibold mb-4">Performance Summary</h2>
          <p class="text-lg">
            <% if @stats.present? %>
              <span class="text-gray-400">Total problems: <%= @stats.sum(:attempts) %></span>,
              <span class="text-green-600">Correct: <%= @stats.sum(:correct_attempts) %></span>,
              <span class="text-red-600">Incorrect: <%= @stats.sum(:attempts) - @stats.sum(:correct_attempts) %></span>
            <% else %>
              <%= @summary %>
            <% end %>
          </p>
        </div>

        <!-- Category Breakdown -->
        <% if @stats.present? %>
          <div>
            <h2 class="text-2xl font-semibold mb-4">Category Breakdown</h2>
            <div class="overflow-y-auto max-h-96">
              <table class="table w-full">
                <thead>
                  <tr class="text-white border-b border-gray-500">
                    <th class="p-2 text-left">Category</th>
                    <th class="p-2 text-left text-gray-600">Attempts</th>
                    <th class="p-2 text-left text-green-600">Correct</th>
                    <th class="p-2 text-left text-red-600">Incorrect</th>
                  </tr>
                </thead>
                <tbody>
                  <% @stats.each do |stat| %>
                    <tr class="border-b border-gray-700 hover:bg-gray-800">
                      <td class="p-3"><%= Category.find(stat.category_id).name %></td>
                      <td class="p-3 text-gray-600"><%= stat.attempts %></td>
                      <td class="p-3 text-green-600"><%= stat.correct_attempts %></td>
                      <td class="p-3 text-red-600"><%= stat.attempts - stat.correct_attempts %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Error Message -->
        <p class="text-lg text-red-500 font-medium">Student not found.</p>
      <% end %>
    </div>
  </div>
</div>