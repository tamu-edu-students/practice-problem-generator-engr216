<head>
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css" rel="stylesheet">
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<div class="w-full flex flex-col bg-gray-100 min-h-screen">
  <!-- Navbar -->
  <div class="navbar bg-gray-900 text-white px-6 w-full fixed top-0 z-50 shadow-lg">
    <div class="flex-1">
      <a href="/teacher_dashboard" class="btn btn-ghost text-white hover:bg-gray-700 hover:text-white transition">
        Dashboard
      </a>
    </div>
    <div class="flex-none">
      <div class="dropdown dropdown-end">
        <button class="btn btn-ghost text-white hover:bg-gray-700 hover:text-white transition">
          Account ▼
        </button>
        <ul class="dropdown-content menu p-2 shadow bg-gray-800 text-white rounded-box w-36">
          <li><a href="/teacher_dashboard" class="hover:bg-gray-700">Dashboard</a></li>
          <li><a href="/logout" class="hover:bg-gray-700">Logout</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="flex flex-col items-center justify-center flex-grow w-full p-6 mt-20">
    <h1 class="text-3xl md:text-4xl font-bold mb-8 text-gray-800">
      <%= "#{@student.first_name} #{@student.last_name}" %>’s Problem History
    </h1>

    <div class="w-full max-w-5xl">
      <% if @student %>
        <!-- Summary Card -->
        <div class="card bg-white shadow-xl mb-6">
          <div class="card-body">
            <h2 class="card-title text-2xl font-semibold text-gray-900">Performance Summary</h2>
            <p class="text-lg text-gray-700">
              <% if @stats.present? %>
                <span class="text-gray-600">Total problems: <%= @stats.sum(:attempts) %></span>,
                <span class="text-green-600">Correct: <%= @stats.sum(:correct_attempts) %></span>,
                <span class="text-red-600">Incorrect: <%= @stats.sum(:attempts) - @stats.sum(:correct_attempts) %></span>
              <% else %>
                <%= @summary %>
              <% end %>
            </p>
          </div>
        </div>

        <!-- Category Breakdown -->
        <% if @stats.present? %>
          <div class="card bg-white shadow-xl">
            <div class="card-body">
              <h2 class="card-title text-2xl font-semibold text-gray-900">Category Breakdown</h2>
              <div class="overflow-x-auto">
                <table class="table w-full text-gray-700">
                  <thead>
                    <tr class="bg-gray-200 text-gray-800">
                      <th class="p-4 text-left">Category</th>
                      <th class="p-4 text-left text-gray-600">Attempts</th>
                      <th class="p-4 text-left text-green-600">Correct</th>
                      <th class="p-4 text-left text-red-600">Incorrect</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @stats.each do |stat| %>
                      <tr class="hover:bg-gray-50">
                        <td class="p-4"><%= Category.find(stat.category_id).name %></td>
                        <td class="p-4 text-gray-600"><%= stat.attempts %></td>
                        <td class="p-4 text-green-600"><%= stat.correct_attempts %></td>
                        <td class="p-4 text-red-600"><%= stat.attempts - stat.correct_attempts %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Error Card -->
        <div class="card bg-white shadow-xl">
          <div class="card-body">
            <p class="text-lg text-red-600 font-medium">Student not found.</p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>